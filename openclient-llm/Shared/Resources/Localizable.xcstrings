    "Your local personal context differs from iCloud. Which version would you like to keep?" : {
      "localizations" : {
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ローカルの個人情報がiCloudと異なります。どちらのバージョンを保持しますか？"
          }
        },
        "es" : {
          "stringUnit" : {
            "value" : "Tu contexto personal local difiere del de iCloud. ¿Qué versión deseas conservar?",
            "state" : "translated"
          }
        },
        "sv" : {
          "stringUnit" : {
            "value" : "Din lokala personliga kontext skiljer sig från iCloud. Vilken version vill du behålla?",
            "state" : "translated"
          }
        },
        "pt-PT" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "O seu contexto pessoal local difere do iCloud. Qual versão pretende manter?"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je lokale persoonlijke context verschilt van iCloud. Welke versie wil je behouden?"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Votre contexte personnel local diffère de celui d’iCloud. Quelle version souhaitez-vous conserver ?"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Το τοπικό προσωπικό σας περιεχόμενο διαφέρει από το iCloud. Ποια έκδοση θέλετε να κρατήσετε;"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr lokaler persönlicher Kontext unterscheidet sich von iCloud. Welche Version möchten Sie behalten?"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Il tuo contesto personale locale differisce da quello di iCloud. Quale versione desideri mantenere?"
          }
        },
        "en" : {
          "stringUnit" : {
            "value" : "Your local personal context differs from iCloud. Which version would you like to keep?",
            "state" : "translated"
          }
        }
