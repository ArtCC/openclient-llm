        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilice estas fuentes para responder a la pregunta del usuario. Cite las fuentes usando el formato [Título de la fuente](URL)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
