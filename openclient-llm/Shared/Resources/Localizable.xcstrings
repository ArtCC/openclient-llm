    "Your gateway to any LLM through a unified interface. Connect to your LiteLLM server and start chatting.": {
      "comment": "Description text on the first onboarding welcome step.",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Zugang zu jedem LLM über eine einheitliche Oberfläche. Verbinde dich mit deinem LiteLLM-Server und beginne zu chatten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η πύλη σου σε οποιοδήποτε LLM μέσα από μια ενιαία διεπαφή. Συνδέσου στον διακομιστή LiteLLM και ξεκίνα τη συνομιλία."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu puerta de entrada a cualquier LLM a través de una interfaz unificada. Conecta con tu servidor LiteLLM y empieza a chatear."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ton accès à n'importe quel LLM via une interface unifiée. Connecte-toi à ton serveur LiteLLM et commence à discuter."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo accesso a qualsiasi LLM tramite un'interfaccia unificata. Connettiti al tuo server LiteLLM e inizia a chattare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "統一されたインターフェースであらゆるLLMへアクセスできます。LiteLLMサーバーに接続してチャットを始めましょう。"
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Jouw toegang tot elk LLM via één interface. Maak verbinding met je LiteLLM-server en begin met chatten."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A tua porta de entrada para qualquer LLM através de uma interface unificada. Liga-te ao teu servidor LiteLLM e começa a conversar."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din ingång till alla LLM:er genom ett enhetligt gränssnitt. Anslut till din LiteLLM-server och börja chatta."
          }
        }
      }
    },
    "Your server is configured and ready to go. Start chatting with your AI models.": {
      "comment": "Description text on the final onboarding step.",
      "localizations": {
        "de": {
          "stringUnit": {
