<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSCameraUsageDescription</key>
	<string>OpenClient LLM uses the camera to capture photos for sending to the AI model.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>OpenClient LLM uses the microphone to record audio for transcription by the AI model.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>OpenClient LLM needs access to your local network to connect to your self-hosted LiteLLM server.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_http._tcp</string>
		<string>_https._tcp</string>
	</array>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>VOTICE_API_KEY</key>
	<string>$(VOTICE_API_KEY)</string>
	<key>VOTICE_API_SECRET</key>
	<string>$(VOTICE_API_SECRET)</string>
	<key>VOTICE_APP_ID</key>
	<string>$(VOTICE_APP_ID)</string>
</dict>
</plist>
